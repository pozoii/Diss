<mujoco model="only_plate">

    <option timestep="0.002" gravity="0 0 -9.81"/>

    <worldbody>


        <!-- ========================= -->
        <!-- BASE -->
        <!-- ========================= -->
        <body name="base" pos="0 0 0">

            <!-- ========================= -->
            <!-- ROLL AXIS -->
            <!-- ========================= -->
            <body name="roll_link" pos="0 0 0.2">

                <inertial mass="0.2" pos="0 0 0"
                          diaginertia="0.01 0.01 0.01"/>

                <joint name="roll"
                       type="hinge"
                       axis="0 -1 0"
                       damping="0.05"/>

                <!-- ========================= -->
                <!-- PITCH AXIS -->
                <!-- ========================= -->
                <body name="pitch_link">

                    <inertial mass="0.2" pos="0 0 0"
                              diaginertia="0.01 0.01 0.01"/>

                    <joint name="pitch"
                           type="hinge"
                           axis="1 0 0"
                           damping="0.05"/>

                    <!-- ========================= -->
                    <!-- PLATE (MOVING SURFACE) -->
                    <!-- ========================= -->
                    <body name="plate_body">

                        <geom name="plate"
                              type="box"
                              size="1 1 0.025"
                              mass="2.0"
                              rgba="0.3 0.5 0.9 1"
                              friction="1.0 0.01 0.001"/>

                    </body>

                </body>

            </body>

        </body>

        <!-- ========================= -->
        <!-- BALL (WORLD FRAME) -->
        <!-- ========================= -->
        <body name="ball" pos="10 10 0.25">

            <freejoint name="ball_joint"/>

            <geom name="ball_geom"
                  type="sphere"
                  size="0.02"
                  mass="0.05"
                  rgba="0.9 0.2 0.2 1"

                  friction="1.2 0.01 0.0005"

                  solref="0.02 1"
                  solimp="0.9 0.95 0.001"/>

        </body>

    </worldbody>
    <!-- ========================= -->
    <!-- ACTUATION -->
    <!-- ========================= -->
    <actuator>

        <motor name="roll_motor"
               joint="roll"
               gear="8"/>

        <motor name="pitch_motor"
               joint="pitch"
               gear="8"/>

    </actuator>

</mujoco>