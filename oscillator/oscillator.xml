<mujoco model="harmonic_oscillator_1d">
    <compiler angle="radian"/>
    <option timestep="0.01" gravity="0 0 0"/>

    <worldbody>
        <!-- Fixed anchor -->
        <body name="mass" pos="0 0 0">

            <inertial pos="0 0 0" mass="1.0" diaginertia="1e-4 1e-4 1e-4"/>
            
            <!-- 1D sliding joint along x-axis with spring -->
            <joint name="slide_x" type="slide" axis="1 0 0" stiffness="10" damping="0"/>

            <!-- Mass -->
            <geom name="mass_geom" type="sphere" size="0.05" rgba="0.2 0.6 0.9 1"/>

        </body>
    </worldbody>

    <!-- Actuator: applies force a_t -->
    <actuator>
        <motor name="force" joint="slide_x" ctrlrange="-50 50" gear="1"/>
    </actuator>
</mujoco>